{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/henrikekblad/codelight/blob/main/companion/config.schema.json",
  "title": "codelight companion config",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "agents": {
      "type": "object",
      "description": "Agent-specific configuration keyed by agent id.",
      "additionalProperties": {
        "type": "object"
      },
      "properties": {
        "claude": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "settings_path": {
              "type": "string",
              "description": "Override Claude settings.json path."
            },
            "credentials_path": {
              "type": "string",
              "description": "Override Claude credentials path used for usage polling."
            }
          }
        },
        "codex": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "home": {
              "type": "string",
              "description": "Override Codex home directory."
            },
            "app_server_usage": {
              "type": "boolean",
              "description": "Use codex app-server account/rateLimits/read for reset-credit-aware usage when available."
            }
          }
        },
        "copilot": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "home": {
              "type": "string",
              "description": "Override Copilot home directory."
            },
            "github_org": {
              "type": "string",
              "description": "GitHub organization slug for optional pooled monthly usage."
            },
            "github_token_file": {
              "type": "string",
              "description": "Path to a token file used for GitHub API usage calls."
            }
          }
        },
        "grok": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "home": {
              "type": "string",
              "description": "Override Grok home directory."
            }
          }
        },
        "cursor": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "home": {
              "type": "string",
              "description": "Override Cursor home directory."
            },
            "state_db": {
              "type": "string",
              "description": "Path to Cursor's IDE state.vscdb (auth store for the usage meter)."
            },
            "usage": {
              "type": "boolean",
              "description": "Show Cursor's monthly included-usage meter via its web API (default true)."
            }
          }
        }
      }
    }
  }
}
