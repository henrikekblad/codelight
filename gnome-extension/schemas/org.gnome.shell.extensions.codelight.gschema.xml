<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <schema id="org.gnome.shell.extensions.codelight"
          path="/org/gnome/shell/extensions/codelight-sensnology-se/">

    <key name="host" type="s">
      <default>'localhost'</default>
      <summary>Daemon hostname or IP address</summary>
    </key>

    <key name="port" type="i">
      <default>8765</default>
      <range min="1" max="65535"/>
      <summary>Daemon WebSocket port</summary>
    </key>

    <key name="secret" type="s">
      <default>''</default>
      <summary>Authentication secret (must match --secret passed to codelight.py)</summary>
    </key>

  </schema>
</schemalist>
