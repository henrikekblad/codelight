{
  "name": "codelight",
  "displayName": "codelight",
  "description": "Coding-agent status (Claude, Copilot, Codex, …) in the VS Code status bar",
  "version": "1.6.0",
  "publisher": "sensnology",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/henrikekblad/codelight"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "codelight",
      "properties": {
        "codelight.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Connect to the codelight companion daemon"
        },
        "codelight.host": {
          "type": "string",
          "default": "127.0.0.1",
          "description": "Companion daemon host"
        },
        "codelight.port": {
          "type": "number",
          "default": 8765,
          "description": "Companion daemon WebSocket port"
        },
        "codelight.secret": {
          "type": "string",
          "default": "",
          "description": "Shared secret (must match the daemon's --secret)"
        },
        "codelight.questionPrompts": {
          "type": "boolean",
          "default": true,
          "description": "Answer supported agent questions in the editor (requires the companion to run with --remote-control)"
        },
        "codelight.permissionPrompts": {
          "type": "boolean",
          "default": true,
          "description": "Handle agent permission prompts in the editor via codelight before VS Code shows its own approval UI"
        }
      }
    },
    "commands": [
      {
        "command": "codelight.answerQuestion",
        "title": "codelight: Review pending request"
      }
    ]
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify",
    "vscode:prepublish": "npm run build",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.5.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.4.0"
  }
}
